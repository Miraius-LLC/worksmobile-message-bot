{
  "name": "worksmobile-message-bot",
  "version": "1.0.0",
  "description": "Webhook bot messenger for LINE WORKS",
  "homepage": "http://miraius.co.jp",
  "repository": {
    "type": "git",
    "url": "https://github.com/Miraius-LLC/worksmobile-message-bot.git"
  },
  "author": {
    "name": "Ayumi Fujii",
    "url": "https://github.com/fujimogn",
    "email": "fujimogn@gmail.com"
  },
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "secrets:inject": "op inject -f -i .env.tpl -o .env",
    "dev": "bun run --hot ./src/index.ts",
    "start": "bun run ./build/index.js",
    "build": "bun build ./src/index.ts --outdir=./build --target=bun --minify",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check ./src ./tests",
    "format": "bunx biome check --write ./src ./tests",
    "docker:build": "docker build -t worksmobile-message-bot .",
    "docker:run": "docker run -p 8080:8080 --env-file=.env worksmobile-message-bot",
    "lefthook:install": "lefthook install"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hono/zod-validator": "^0.8.0",
    "hono": "^4.12.25",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.9",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3"
  },
  "license": "MIT"
}
