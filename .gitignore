# =============================================================================
# Project-specific
# =============================================================================

# 添付ファイルの一時保管 (アプリ runtime / dev で生成される可能性のあるディレクトリ)
uploads/
downloads/
download/

# Build (Docker ビルド時に bun build で生成)
build/

# LINE WORKS の RSA 秘密鍵 (誤コミット防御。`base64 -i ./private_*.key` で .env に変換)
private_*.key
*.pem

# =============================================================================
# Secrets / Env
# =============================================================================

# 実体は 1Password から op inject で生成。テンプレート .env.tpl のみ tracked
.env
.env.*
!.env.tpl

# =============================================================================
# Bun / Node
# =============================================================================

node_modules/
bun.lockb
*.tsbuildinfo
.npm

# =============================================================================
# Claude Code
# =============================================================================

.claude/settings.local.json
.claude/worktrees/

# =============================================================================
# IDE / Editor
# =============================================================================

# VSCode (workspace ファイルや local 履歴は除外、共有設定 (.vscode/*.json 等) は許可)
*.code-workspace
.code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
*.vsix

# JetBrains
.idea/

# Local History for Visual Studio Code
.history/

# =============================================================================
# OS
# =============================================================================

.DS_Store
Thumbs.db
*.swp

# =============================================================================
# Logs / runtime data
# =============================================================================

logs/
*.log
*.pid
*.pid.lock

# =============================================================================
# Test / Coverage
# =============================================================================

coverage/
*.lcov
.nyc_output/
